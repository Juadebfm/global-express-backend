# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Database (Neon Serverless PostgreSQL) ───────────────────────────────────
DATABASE_URL=
# Dedicated, disposable database used only by the full migration integration test.
# Never point this at a shared, staging, or production database.
MIGRATION_TEST_DATABASE_URL=

# ─── Clerk Authentication ────────────────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Webhook signing secret — Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=

# ─── Cloudflare R2 (S3-compatible) ───────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── Resend Email ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=

# ─── Termii SMS / WhatsApp (optional) ────────────────────────────────────────
TERMII_API_KEY=
# Alphanumeric sender ID shown to recipients (max 11 chars). Defaults to "talert" on trial.
TERMII_SENDER_ID=
# Channel: generic (SMS), dnd (DND route), whatsapp. Defaults to "generic".
# Set to "whatsapp" only after completing Termii WhatsApp Business registration.
TERMII_CHANNEL=generic

# ─── Paystack ────────────────────────────────────────────────────────────────
# Use sk_test_* / pk_test_* in dev. PRODUCTION MUST use sk_live_* / pk_live_*
# (enforced by `npm run audit:secrets:prod`).
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ─── Internal JWT (staff / admin / superadmin auth — NOT Clerk) ──────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ─── Encryption ──────────────────────────────────────────────────────────────
# 64-character hex string (32 bytes) for AES-256.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotation procedure: docs/key-rotation-runbook.md — rotating without re-encrypt
# migration will make every encrypted column unreadable.
ENCRYPTION_KEY=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Must NOT contain "*" — explicit only.
# This list also constrains Paystack callbackUrl values (open-redirect guard).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ─── Admin IP allowlist (optional) ───────────────────────────────────────────
# Comma-separated list of IPv4 / IPv6 / CIDR ranges allowed to reach
# /auth/login and /internal/auth/login. Leave blank in dev to disable.
# In prod, set to your VPN egress IPs (e.g. 1.2.3.4,5.6.7.0/24).
ADMIN_IP_WHITELIST=

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: URL or an https URL identifying the sender.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# ─── OpenTelemetry tracing (optional) ────────────────────────────────────────
# Setting OTEL_EXPORTER_OTLP_ENDPOINT enables tracing instrumentation.
# Examples:
#   Local Tempo/Jaeger: http://localhost:4318/v1/traces
#   Honeycomb:          https://api.honeycomb.io/v1/traces (also set OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_KEY)
#   Grafana Cloud:      https://otlp-gateway-<region>.grafana.net/otlp/v1/traces
# Leave blank to disable — zero overhead.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=global-express-backend

# ─── Cloudflare Turnstile CAPTCHA (optional in dev) ──────────────────────────
# Wired to public mutation endpoints (newsletter, gallery claims, D2D intake).
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
# In dev, leave blank — middleware no-ops.
TURNSTILE_SECRET_KEY=
# Force CAPTCHA enforcement even without a key (rejects every request).
# Useful for testing failure paths locally. Leave unset in production.
TURNSTILE_REQUIRE=

# ─── VirusTotal AV scanning (optional in dev) ────────────────────────────────
# Scans every confirmed upload (receipts, claim proofs, invoice attachments).
# Get from: https://www.virustotal.com/gui/my-apikey (free tier: 4 req/min, 500/day).
# In dev, leave blank — uploads marked `skipped` and staff UI sees that status.
VIRUSTOTAL_API_KEY=
