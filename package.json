{
  "name": "global-express-backend",
  "version": "1.0.0",
  "description": "Shipment Order Tracking System Backend API",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:secrets": "tsx scripts/audit-env-secrets.ts",
    "audit:secrets:prod": "tsx scripts/audit-env-secrets.ts --prod",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts apply",
    "db:migrate:apply": "tsx scripts/migrate.ts apply",
    "db:migrate:status": "tsx scripts/migrate.ts status",
    "db:migrate:baseline": "tsx scripts/migrate.ts baseline",
    "db:migrate:repair": "tsx scripts/run-all-migrations.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed:superadmin": "tsx scripts/seed-superadmin.ts",
    "seed:data": "tsx scripts/seed-data.ts",
    "seed:gallery": "tsx scripts/seed-gallery.ts",
    "seed:gallery:cleanup": "tsx scripts/cleanup-gallery-seed.ts",
    "seed:gabriel": "tsx scripts/seed-dashboard-user.ts",
    "seed:gabriel2": "tsx scripts/seed-gabriel2.ts",
    "backfill:status-v2": "tsx scripts/backfill-status-v2.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@clerk/backend": "^3.2.11",
    "@fastify/cors": "^10.0.2",
    "@fastify/etag": "^6.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/websocket": "^11.0.2",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "axios": "^1.15.2",
    "axios-retry": "^4.5.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-metrics": "^13.2.0",
    "fastify-type-provider-zod": "^6.1.0",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.17.2",
    "postgres": "^3.4.5",
    "resend": "^4.8.0",
    "svix": "^1.92.2",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.4",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^3.0.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-promise": "^7.3.0",
    "prettier": "^3.8.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
