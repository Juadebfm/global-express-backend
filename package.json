{
  "name": "global-express-backend",
  "version": "1.0.0",
  "description": "Shipment Order Tracking System Backend API",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed:superadmin": "tsx scripts/seed-superadmin.ts",
    "seed:data": "tsx scripts/seed-data.ts",
    "seed:gallery": "tsx scripts/seed-gallery.ts",
    "seed:gallery:cleanup": "tsx scripts/cleanup-gallery-seed.ts",
    "seed:gabriel": "tsx scripts/seed-dashboard-user.ts",
    "seed:gabriel2": "tsx scripts/seed-gabriel2.ts",
    "backfill:status-v2": "tsx scripts/backfill-status-v2.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@clerk/backend": "^3.2.11",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/websocket": "^11.0.2",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.17.2",
    "postgres": "^3.4.5",
    "resend": "^4.8.0",
    "svix": "^1.92.2",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.4",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^3.0.5",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
